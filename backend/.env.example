# Backend Configuration
PORT=3000
NODE_ENV=production

# Protect all /api routes when set
PUMP_API_KEY=replace-with-a-long-random-secret

# Optional: password used by /api/reservations/refresh
# PUMP_SESSION_PASSWORD=replace-with-login-password

# Allowed frontend origins for CORS (comma-separated)
FRONTEND_URL=http://localhost:5174

# Optional: Data directory (defaults to ./data relative to repo root)
DATA_DIR=./data

# Optional: frontend dist folder served by Express in production
# FRONTEND_DIST_DIR=./frontend/dist

# Recommended for servers and containers
PLAYWRIGHT_HEADLESS=true
# PLAYWRIGHT_DISABLE_SANDBOX=true
